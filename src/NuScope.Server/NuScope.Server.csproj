<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Raiqub.NuScope</RootNamespace>
    <AssemblyName>Raiqub.NuScope</AssemblyName>
    <PackageId>Raiqub.NuScope</PackageId>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>nuscope</ToolCommandName>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="ModelContextProtocol" />
    <PackageReference Include="TestableIO.System.IO.Abstractions.Wrappers" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\logos\logo-128.png" Pack="true" PackagePath="icon.png" />
  </ItemGroup>
</Project>
